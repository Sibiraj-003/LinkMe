rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // users
    match /users/{userId} {
      allow read: if true; // Basic info might be needed for public display
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
    }

    // cards
    match /cards/{userId} {
      allow read: if true; // Public access for visiting cards
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
    }

    // portfolios
    match /portfolios/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
    }

    // analytics
    match /analytics/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if true; // Need to allow unauthenticated or other users to log stats incrementally (or via cloud function, but here we allow anyone to write stats, ideally using FieldValue.increment)
      allow update: if true; 
    }

    // settings
    match /settings/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
    }
  }
}
